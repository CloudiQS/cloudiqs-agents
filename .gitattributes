# Force LF line endings for all text files — CRLF breaks bash scripts on Linux/WSL
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# These are also LF-sensitive
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Windows-only files can keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
